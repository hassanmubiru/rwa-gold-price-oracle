# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# Private key for the funded Sepolia testnet wallet.
# Must correspond to an account with Sepolia ETH for gas fees.
# Get testnet ETH at: https://faucets.chain.link/
CRE_ETH_PRIVATE_KEY=YOUR_FUNDED_SEPOLIA_PRIVATE_KEY_HERE
